import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt

# Load data
df = pd.read_csv("data/sample_data.csv")

# Base Cleaning (actually base on operational knowledge. However, due to confidential, I use quantile here
df = df[
    (df['feature_c'].notna()) &
    (df['feature_b'].notna()) &
    (df['feature_c'] < df['feature_c'].quantile(0.99)) &
    (df['feature_b'] < df['feature_b'].quantile(0.99))
]

# Target Labeling
df['target_high'] = np.where(df['target_metric'] > df['target_metric'].median(), 'high', 'low')
df['premium_label'] = np.where(
    (df['metric_1'] <= df['metric_1'].quantile(0.7)) &
    (df['target_metric'] >= df['target_metric'].quantile(0.6)) &
    (df['metric_2'].between(df['metric_2'].quantile(0.2), df['metric_2'].quantile(0.8))) &
    (df['metric_3'] < df['metric_3'].quantile(0.75)),
    'premium',
    'non_premium'
)

# Feature Summary
def analyze_feature_ranges(df, feature_list):
    summary = df.groupby('premium_label')[feature_list].agg(
        ['min', 'max', 'mean', 'median', 'std', 'count']
    )
    return summary.round(4)
features = df.select_dtypes(include=['float64', 'int64']).columns
features = features.drop(['target_metric'], errors='ignore')
summary = analyze_feature_ranges(df, features)

# Correlation Scan
def correlation_scan(df, target, features):
    results = []
    for col in features:
        temp = df[[col, target]].dropna()
        results.append({
            "feature": col,
            "pearson": temp[col].corr(temp[target]),
            "spearman": temp[col].corr(temp[target], method="spearman")
        })
    out = pd.DataFrame(results)
    out["strength"] = out[["pearson", "spearman"]].abs().max(axis=1)
    return out.sort_values("strength", ascending=False)
corr_table = correlation_scan(df, 'target_metric', features)

def heatmap_with_target(df, target, features):
    cols = list(features) + [target]
    corr = df[cols].corr()
    corr_target = corr[[target]].drop(index=target)
    plt.figure(figsize=(6, len(features) * 0.4))
    sns.heatmap(
        corr_target.sort_values(by=target, ascending=False),
        cmap="coolwarm",
        center=0,
        annot=True
    )
    plt.title(f"Correlation with {target}")
    plt.tight_layout()
    plt.show()
heatmap_with_target(df, 'target_metric', features)

# Bin Analysis
def analyze_bins(df, col, bins=5):
    df[f'{col}_bin'] = pd.qcut(df[col], q=bins, duplicates='drop')
    result = df.groupby(f'{col}_bin')['target_metric'].agg(
        mean='mean',
        std='std',
        count='count'
    ).reset_index()
    return result.sort_values(by='mean', ascending=False)

for col in ['feature_a', 'feature_b', 'feature_c']:
    print(analyze_bins(df, col, bins=5))

# Combination Analysis (to find optimal range, remove data noise by count
df = df.dropna(subset=['feature_a', 'feature_b', 'feature_c', 'target_metric'])
df['a_bin'] = pd.qcut(df['feature_a'], q=4, duplicates='drop')
df['b_bin'] = pd.qcut(df['feature_b'], q=4, duplicates='drop')
df['c_bin'] = pd.qcut(df['feature_c'], q=4, duplicates='drop')
combo = df.groupby(['a_bin','b_bin','c_bin']).agg(
    mean_target=('target_metric','mean'),
    count=('target_metric','count')
).reset_index()
combo = combo[combo['count'] >= 30]
combo = combo.sort_values(by='mean_target', ascending=False)
print(combo.head(10))

# Trade-off Analysis
# Stable condition
df_oper = df[
    df['feature_a'].between(df['feature_a'].quantile(0.4), df['feature_a'].quantile(0.7))
]
# Ideal condition
df_ideal = df[
    (df['feature_a'] < df['feature_a'].quantile(0.3)) &
    (df['feature_b'] < df['feature_b'].quantile(0.3))
]
print("Operational mean:", df_oper['target_metric'].mean())
print("Ideal mean:", df_ideal['target_metric'].mean())

def high_rate(series):
    return (series > series.median()).mean()
print("Operational high rate:", high_rate(df_oper['target_metric']))
print("Ideal high rate:", high_rate(df_ideal['target_metric']))
